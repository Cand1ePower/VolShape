ENV=development
POSTGRES_DB=volshape
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-a-strong-postgres-password
DATABASE_URL=postgresql+asyncpg://postgres:localpassword123@localhost:5432/volshape
REDIS_URL=redis://localhost:6379/0
CORS_ORIGINS=http://localhost:8081,http://127.0.0.1:8081,http://localhost:19006,http://127.0.0.1:19006
SUPABASE_JWT_SECRET=your-supabase-jwt-secret-here

# DeepSeek LLM API
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
LLM_LIGHT_MODEL=deepseek-chat
LLM_HEAVY_MODEL=deepseek-chat
LLM_VISION_MODEL=deepseek-chat
VISION_API_KEY=
VISION_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# VolShape first-party auth
AUTH_JWT_SECRET=replace-with-a-long-random-secret
AUTH_ACCESS_TOKEN_EXPIRE_MINUTES=15
AUTH_REFRESH_TOKEN_EXPIRE_DAYS=30
TOKEN_ENCRYPTION_SECRET=replace-with-a-different-long-random-secret

# New API gateway
NEWAPI_BASE_URL=https://api.candlepower.cool
NEWAPI_ACCESS_TOKEN=replace-with-newapi-access-token
NEWAPI_USER_ID=1
# Backward-compatible aliases. Prefer NEWAPI_ACCESS_TOKEN / NEWAPI_USER_ID.
NEWAPI_SYSTEM_TOKEN=
NEWAPI_ADMIN_USER_ID=
NEWAPI_SHARED_TOKEN=
NEWAPI_DEFAULT_FREE_GROUP=free
NEWAPI_DEFAULT_PRO_GROUP=pro
NEWAPI_DEFAULT_PREMIUM_GROUP=premium
NEWAPI_SERVER_ALLOW_IPS=
NEWAPI_AUTO_PROVISION_TOKENS=1

# FatSecret nutrition API
FATSECRET_AUTH_MODE=auto
FATSECRET_CONSUMER_KEY=
FATSECRET_CONSUMER_SECRET=
FATSECRET_CLIENT_ID=your-fatsecret-client-id
FATSECRET_CLIENT_SECRET=your-fatsecret-client-secret
FATSECRET_TOKEN_URL=https://oauth.fatsecret.com/connect/token
FATSECRET_API_BASE_URL=https://platform.fatsecret.com/rest/server.api
MAX_IMAGE_UPLOAD_MB=10
MAX_VIDEO_UPLOAD_MB=50

# Tavily Web Search
TAVILY_API_KEY=tvly-your-tavily-api-key-here

# Langfuse Observability
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com
